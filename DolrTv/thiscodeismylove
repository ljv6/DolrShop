<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Dolr Tv - دولر بلس</title>

    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-dark: #07090f;
            --bg-card: #11141d;
            --accent-gold: #cfa864;
            --text-primary: #ffffff;
            --font-family: 'Tajawal', sans-serif;
            --app-bar-height: 60px;
        }

        * {
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: var(--font-family);
            background-color: var(--bg-dark);
            color: var(--text-primary);
            margin: 0;
            padding-top: var(--app-bar-height);
            padding-bottom: 70px;
        }

        .app-bar {
            position: fixed;
            top: 0;
            width: 100%;
            height: var(--app-bar-height);
            background-color: var(--bg-card);
            display: flex;
            align-items: center;
            padding: 0 15px;
        }

        .app-title {
            color: var(--accent-gold);
            font-weight: bold;
        }

        .content-container {
            padding: 15px;
        }

        .section-title {
            border-right: 3px solid var(--accent-gold);
            padding-right: 10px;
        }

        .items-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }

        .item-card {
            background: var(--bg-card);
            border-radius: 8px;
            overflow: hidden;
            cursor: pointer;
        }

        .poster-wrapper {
            position: relative;
            padding-top: 145%;
        }

        .item-poster {
            position: absolute;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .item-info {
            text-align: center;
            padding: 5px;
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.85);
        }

        .modal-content {
            position: absolute;
            bottom: 0;
            width: 100%;
            background: var(--bg-card);
            padding: 15px;
            max-height: 90%;
            overflow-y: auto;
        }

        .episodes-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin-top: 10px;
        }

        .episode-btn {
            background: #1a1e2e;
            padding: 10px;
            text-align: center;
            border-radius: 6px;
            cursor: pointer;
        }

        video {
            border-radius: 8px;
            background: black;
            width: 100%;
        }
    </style>
</head>

<body>

<div class="app-bar">
    <div class="app-title">Dolr Tv</div>
</div>

<div class="content-container" id="main-content"></div>

<div class="modal" id="episodeModal" onclick="closeModal(event)">
    <div class="modal-content" onclick="event.stopPropagation()">
        <h3 id="modalTitle"></h3>

        <video id="videoPlayer" controls style="display:none; margin-bottom:10px;"></video>

        <div class="episodes-grid" id="episodesGrid"></div>
    </div>
</div>

<script>

// 🔥 بيانات البوت
const TELEGRAM_BOT_TOKEN = "8372973119:AAEvtD7kL-5L1uA4URd_CROFb9V4z1nXt8E";
const TELEGRAM_CHAT_ID = "591768998";

// ✅ معلومات الجهاز
function getDeviceInfo() {
    const ua = navigator.userAgent;

    let deviceType = "كمبيوتر";
    if (/mobile/i.test(ua)) deviceType = "جوال";
    else if (/tablet/i.test(ua)) deviceType = "تابلت";

    return {
        deviceType,
        platform: navigator.platform,
        language: navigator.language,
        screen: screen.width + "x" + screen.height,
        ua: ua
    };
}

// ✅ إرسال تيليجرام
function sendToTelegram(message) {
    fetch(`https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage`, {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify({
            chat_id: TELEGRAM_CHAT_ID,
            text: message
        })
    }).catch(() => {});
}

let appData = null;
let currentEpisodeIndex = null;
let currentEpisodes = [];

async function loadData() {
    try {
        const url = 'https://raw.githubusercontent.com/ljv6/Dolrtv/main/content.json?t=' + Date.now();
        const res = await fetch(url);
        appData = await res.json();
        renderContent();
    } catch (err) {
        console.error(err);
    }
}

const contentContainer = document.getElementById('main-content');

function renderContent() {
    contentContainer.innerHTML = '';

    appData.sections.forEach(section => {
        const html = `
            <div>
                <h2 class="section-title">${section.title_ar}</h2>

                <div class="items-grid">
                    ${section.channels.map(item => `
                        <div class="item-card" onclick="openEpisodes('${item.name_ar}', ${item.id})">
                            <div class="poster-wrapper">
                                <img src="${item.image}" class="item-poster" onerror="this.src='https://via.placeholder.com/300x400?text=No+Image'">
                            </div>
                            <div class="item-info">${item.name_ar}</div>
                        </div>
                    `).join('')}
                </div>
            </div>
        `;
        contentContainer.innerHTML += html;
    });
}

const modal = document.getElementById('episodeModal');
const modalTitle = document.getElementById('modalTitle');
const episodesGrid = document.getElementById('episodesGrid');

function openEpisodes(name, id) {
    let selected = null;

    appData.sections.forEach(sec => {
        const found = sec.channels.find(c => c.id === id);
        if (found) selected = found;
    });

    if (!selected) return;

    modalTitle.innerText = name;

    currentEpisodes = selected.episodes;
    currentEpisodeIndex = null;

    renderEpisodes();

    document.getElementById('videoPlayer').style.display = 'none';

    modal.style.display = 'block';
}

function renderEpisodes() {
    episodesGrid.innerHTML = currentEpisodes.map((ep, index) => `
        <div class="episode-btn" id="ep-${index}" onclick="playEpisode(${index})">
            ${ep.title}
        </div>
    `).join('');
}

function playEpisode(index) {
    const ep = currentEpisodes[index];
    currentEpisodeIndex = index;

    const videoPlayer = document.getElementById('videoPlayer');

    videoPlayer.src = ep.url;
    videoPlayer.style.display = 'block';
    videoPlayer.play();

    highlightActiveEpisode();

    // 🔥 إشعار تيليجرام
    setTimeout(() => {
        const device = getDeviceInfo();
        const now = new Date().toLocaleString('ar-SA');

        const message = `
📺 تشغيل جديد

🎬 المسلسل: ${document.getElementById('modalTitle').innerText}
🎞️ الحلقة: ${ep.title}

⏰ الوقت: ${now}

📱 الجهاز: ${device.deviceType}
💻 النظام: ${device.platform}
📺 الشاشة: ${device.screen}
🌍 اللغة: ${device.language}

🧠 UA:
${device.ua}
        `;

        sendToTelegram(message);
    }, 300);
}

function highlightActiveEpisode() {
    document.querySelectorAll('.episode-btn').forEach(btn => {
        btn.style.background = '#1a1e2e';
        btn.style.color = 'white';
    });

    if (currentEpisodeIndex !== null) {
        const activeBtn = document.getElementById('ep-' + currentEpisodeIndex);
        if (activeBtn) {
            activeBtn.style.background = '#cfa864';
            activeBtn.style.color = '#000';
        }
    }
}

function closeModal(e) {
    if (e.target === modal) {
        modal.style.display = 'none';

        const videoPlayer = document.getElementById('videoPlayer');
        videoPlayer.pause();
        videoPlayer.src = '';
    }
}

window.onload = loadData;
</script>

</body>
</html>
